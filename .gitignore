# Harness — never commit local permission overrides (holds bypassPermissions)
.claude/settings.local.json

# Editor / IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets — model API keys come from the environment, never the repo
.env
.env.*
*.pem
*credentials*

# Python (language chosen with the first real slice: stdlib-only runtime, pytest for dev)
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.venv/

# Gate output artifacts (reports/manifests are build products, not source)
out/
